# ============================================
# Database
# ============================================
DATABASE_URL="postgresql://connecta:connectapass@localhost:5432/connectadb?schema=public"
POSTGRES_USER=connecta
POSTGRES_PASSWORD=connectapass
POSTGRES_DB=connectadb

# ============================================
# Redis
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# Auth (NextAuth.js)
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# OAuth - Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth - GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================
# Server
# ============================================
PORT=4000
NODE_ENV=development
CLIENT_URL="http://localhost:3000"

# ============================================
# File Storage
# ============================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=26214400

# S3 (optional - for production)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# AWS_S3_BUCKET=""

# ============================================
# Email (optional - for invitations)
# ============================================
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# EMAIL_FROM="noreply@example.com"
